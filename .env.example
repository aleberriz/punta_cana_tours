# Copy to .env and fill in (never commit .env). Or export these in your shell.

# --- Google Ads API (scripts/fetch_google_ads.py) ---
# Developer token: only from a Manager account → API Center (not available on client accounts alone).
GOOGLE_ADS_DEVELOPER_TOKEN=
# Client account to query (10 digits, no dashes)
GOOGLE_ADS_CUSTOMER_ID=
# Required when using a token issued under an MCC: the manager account id (10 digits)
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- GA4 Data API (optional; scripts/fetch_ga4.py uses --oauth-client file mainly) ---
# GA4_PROPERTY_ID=452157058
